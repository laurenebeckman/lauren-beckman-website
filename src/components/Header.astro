---
import { SITE_TITLE } from '../consts';
---

<header class="sticky top-0 z-50 bg-background/95 dark:bg-dark-background/95 backdrop-blur-md border-b border-border">
  <nav class="max-w-6xl mx-auto px-6 py-5">
    <div class="flex items-center justify-between">
      <!-- Logo -->
      <a href="/" 
         class="font-serif text-2xl font-bold tracking-tighter text-foreground 
                hover:text-primary transition-all duration-300 hover:scale-105 active:scale-95">
        {SITE_TITLE}
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-8 text-sm font-medium">
        <a href="/" 
           class="relative py-1 hover:text-pink transition-colors duration-200 group">
          Home
          <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-pink group-hover:w-full transition-all duration-300"></span>
        </a>
        <a href="/#essays" 
           class="relative py-1 hover:text-pink transition-colors duration-200 group">
          Essays
          <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-pink group-hover:w-full transition-all duration-300"></span>
        </a>
        <a href="/#recipes" 
           class="relative py-1 hover:text-pink transition-colors duration-200 group">
          Recipes
          <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-pink group-hover:w-full transition-all duration-300"></span>
        </a>
        <a href="/#photography" 
           class="relative py-1 hover:text-pink transition-colors duration-200 group">
          Photography
          <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-pink group-hover:w-full transition-all duration-300"></span>
        </a>
        <a href="/about" 
           class="relative py-1 hover:text-pink transition-colors duration-200 group">
          About
          <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-pink group-hover:w-full transition-all duration-300"></span>
        </a>
      </div>

      <!-- Social Icons + Mobile Button -->
      <div class="flex items-center gap-6">
        <!-- Social Icons -->
        <div class="hidden md:flex items-center gap-5">
          <a href="https://www.instagram.com/laurenebeckman_/" target="_blank" 
             class="text-foreground hover:text-pink hover:scale-110 active:scale-95 transition-all duration-200" aria-label="Instagram">
            <!-- Instagram SVG -->
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>
          <a href="https://x.com/laurenebeckman" target="_blank" 
             class="text-foreground hover:text-foreground dark:hover:text-white hover:scale-110 active:scale-95 transition-all duration-200" aria-label="X">
            <!-- X SVG -->
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.733-8.835L1.254 2.25H8.08l4.253 5.622 5.91-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <a href="https://www.linkedin.com/in/laurenebeckman/" target="_blank" 
             class="text-foreground hover:text-primary hover:scale-110 active:scale-95 transition-all duration-200" aria-label="LinkedIn">
            <!-- LinkedIn SVG -->
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>
            </svg>
          </a>
        </div>

        <!-- Hamburger -->
        <button id="mobile-menu-button"
                class="md:hidden text-3xl leading-none w-10 h-10 flex items-center justify-center hover:text-pink hover:scale-110 active:scale-95 transition-all duration-200">
          ☰
        </button>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden mt-6 pt-6 border-t border-border">
      <div class="flex flex-col gap-6 text-lg font-medium">
        <a href="/" class="hover:text-pink transition-colors">Home</a>
        <a href="/#essays" class="hover:text-pink transition-colors">Essays</a>
        <a href="/#recipes" class="hover:text-pink transition-colors">Recipes</a>
        <a href="/#photography" class="hover:text-pink transition-colors">Photography</a>
        <a href="/about" class="hover:text-pink transition-colors">About</a>
      </div>
    </div>
  </nav>
</header>

<script>
  const button = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');

  if (button && menu) {
    button.addEventListener('click', () => {
      menu.classList.toggle('hidden');
      button.textContent = menu.classList.contains('hidden') ? '☰' : '✕';
    });
  }
</script>