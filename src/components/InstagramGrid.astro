<section id="photography" class="max-w-6xl mx-auto px-6 py-16">
  <h2 class="text-4xl font-bold tracking-tight text-center mb-12">Photography</h2>
  
  <div class="columns-1 sm:columns-2 lg:columns-3 gap-6 space-y-6">
    {instagramPosts.map((post) => (
      <a 
        href={post.url} 
        target="_blank"
        class="group block break-inside-avoid"
      >
        <div class="relative overflow-hidden rounded-3xl shadow-md group-hover:shadow-2xl transition-all duration-300">
          <img 
            src={post.img} 
            alt={post.caption}
            class="w-full aspect-[4/5] object-cover group-hover:scale-105 transition-transform duration-500"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-all duration-300 flex items-end p-6">
            <p class="text-white text-sm leading-snug line-clamp-3">
              {post.caption}
            </p>
          </div>
        </div>
      </a>
    ))}
  </div>

  <div class="text-center mt-12">
    <a 
      href="https://www.instagram.com/laurenebeckman_/" 
      target="_blank"
      class="inline-flex items-center gap-3 text-lg font-medium hover:text-pink-500 transition-colors"
    >
      See more on Instagram →
    </a>
  </div>
</section>